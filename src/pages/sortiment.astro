---
import BaseLayout from "../layouts/BaseLayout.astro";
import { catalogSections } from "../shared/catalog.js";

function getImageSize(source) {
  const match = source.match(/-(\d+)x(\d+)\.(?:jpe?g|png|webp|svg)$/i);
  if (!match) {
    return { width: 600, height: 400 };
  }

  return {
    width: Number(match[1]),
    height: Number(match[2])
  };
}
---

<BaseLayout
  title={"Sortiment | Duschrinnen Profi"}
  description={"Das Sortiment von Duschrinnen Profi ist klar nach Kategorien gegliedert und zeigt die passenden Originalbilder und Produkttexte pro Artikel."}
  page={"sortiment"}
  ogTitle={"Sortiment | Duschrinnen Profi"}
  ogDescription={"Das Sortiment von Duschrinnen Profi ist klar nach Kategorien gegliedert und zeigt die passenden Originalbilder und Produkttexte pro Artikel."}
>
  <main id="main" data-catalog-root>
    <section class="subhero section-band">
      <div class="layout subhero-grid">
        <div data-reveal>
          <p class="eyebrow" data-sortiment-hero-eyebrow>Sortiment</p>
          <h1 data-sortiment-hero-title>Duschrinnen, Abläufe und Zubehör für professionelle Badprojekte.</h1>
          <p data-sortiment-hero-text>
            Finden Sie Edelstahl- und befliesbare Duschrinnen, Bodenabläufe, Ersatzteile, Duschablagen und Fliesenwerkzeug für Neubau, Renovierung und barrierearme Badezimmer.
          </p>
        </div>
        <div class="subhero-card" data-reveal>
          <span data-sortiment-card-label>Produktübersicht</span>
          <strong data-sortiment-card-title>Originalprodukte mit Preis, Bildern und passenden Kategorien.</strong>
          <p data-sortiment-card-text>Alle wichtigen Produktbereiche von Duschrinnen Profi sind direkt erreichbar - von Duschrinnen bis Fliesenzubehör.</p>
          <button class="button button-ghost catalog-reset" type="button" data-catalog-reset hidden>Alle Kategorien anzeigen</button>
        </div>
      </div>
    </section>

    {
      catalogSections.map((section, sectionIndex) => (
        <section class={`section-band catalog-section ${sectionIndex % 2 === 1 ? "soft-band" : ""}`} id={section.id}>
          <div class="layout">
            <div class="section-heading align-left" data-reveal>
              <p class="eyebrow" data-catalog-eyebrow={section.id}>{section.eyebrow}</p>
              <h2 data-catalog-title={section.id}>{section.title}</h2>
              <p data-catalog-text={section.id}>{section.description}</p>
            </div>

            {
              section.subsections ? (
                <div class="catalog-subsections">
                  {section.subsections.map((subsection) => (
                    <section class="catalog-subsection" id={subsection.id}>
                      <div class="catalog-subsection-head" data-reveal>
                        <h3 data-catalog-subtitle={subsection.id}>{subsection.title}</h3>
                        <p data-catalog-subtext={subsection.id}>{subsection.description}</p>
                      </div>
                      <div class="product-grid product-grid-wide">
                        {subsection.products.map((product) => {
                          const imageSize = getImageSize(product.image);

                          return (
                            <article class="product-card" id={product.id} data-reveal>
                              <div class="product-media-shell">
                                <div
                                  class="product-media"
                                  data-product-media
                                  data-product-title={product.title}
                                  data-gallery={product.gallery.join("|")}
                                  tabindex="0"
                                  role="button"
                                  aria-label={`${product.title} vergrößern`}
                                >
                                  <img
                                    src={product.image}
                                    width={imageSize.width}
                                    height={imageSize.height}
                                    loading="lazy"
                                    decoding="async"
                                    alt={product.title}
                                  />
                                </div>
                                <button
                                  class="icon-button product-media-action"
                                  type="button"
                                  data-open-viewer={product.title}
                                  aria-label={`${product.title} Galerie öffnen`}
                                >
                                  <i data-lucide="scan-search" aria-hidden="true"></i>
                                </button>
                              </div>
                              <div class="product-body">
                                <p class="product-tag">{product.category}</p>
                                <h3><a href={product.url}>{product.title}</a></h3>
                                <p class="product-body-copy">{product.description || product.cardDescription}</p>
                                <div class="product-meta">
                                  <strong>{product.price}</strong>
                                  {product.meta ? <span>{product.meta}</span> : null}
                                </div>
                                <a class="button button-card button-explore" href={product.url} data-explore-product>
                                  <i data-lucide="arrow-up-right" aria-hidden="true"></i>Explore
                                </a>
                              </div>
                            </article>
                          );
                        })}
                      </div>
                    </section>
                  ))}
                </div>
              ) : (
                <div class="product-grid product-grid-wide">
                  {section.products.map((product) => {
                    const imageSize = getImageSize(product.image);

                    return (
                      <article class="product-card" id={product.id} data-reveal>
                        <div class="product-media-shell">
                          <div
                            class="product-media"
                            data-product-media
                            data-product-title={product.title}
                            data-gallery={product.gallery.join("|")}
                            tabindex="0"
                            role="button"
                            aria-label={`${product.title} vergrößern`}
                          >
                            <img
                              src={product.image}
                              width={imageSize.width}
                              height={imageSize.height}
                              loading="lazy"
                              decoding="async"
                              alt={product.title}
                            />
                          </div>
                          <button
                            class="icon-button product-media-action"
                            type="button"
                            data-open-viewer={product.title}
                            aria-label={`${product.title} Galerie öffnen`}
                          >
                            <i data-lucide="scan-search" aria-hidden="true"></i>
                          </button>
                        </div>
                        <div class="product-body">
                          <p class="product-tag">{product.category}</p>
                          <h2><a href={product.url}>{product.title}</a></h2>
                          <p class="product-body-copy">{product.description || product.cardDescription}</p>
                          <div class="product-meta">
                            <strong>{product.price}</strong>
                            {product.meta ? <span>{product.meta}</span> : null}
                          </div>
                          <a class="button button-card button-explore" href={product.url} data-explore-product>
                            <i data-lucide="arrow-up-right" aria-hidden="true"></i>Explore
                          </a>
                        </div>
                      </article>
                    );
                  })}
                </div>
              )
            }
          </div>
        </section>
      ))
    }
  </main>
</BaseLayout>
