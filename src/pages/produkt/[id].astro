---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCatalogContext, getProductById, getRelatedProducts, products } from "../../shared/catalog.js";

function getImageSize(source) {
  const match = source.match(/-(\d+)x(\d+)\.(?:jpe?g|png|webp|svg)$/i);
  if (!match) {
    return { width: 900, height: 700 };
  }

  return {
    width: Number(match[1]),
    height: Number(match[2])
  };
}

export function getStaticPaths() {
  return products.map(function (product) {
    return {
      params: { id: product.id },
      props: {
        productId: product.id
      }
    };
  });
}

const { productId } = Astro.props;
const product = getProductById(productId);
const context = getCatalogContext(productId);
const relatedProducts = getRelatedProducts(productId, 4);
const heroImage = product.gallery[0] || product.image;
const anchorTarget = context ? (context.subsection ? context.subsection.id : context.section.id) : "sortiment";
const sectionTitle = context ? (context.subsection ? context.subsection.title : context.section.title) : product.category;
const sectionDescription = context ? (context.subsection ? context.subsection.description : context.section.description) : "";
const facts = [
  { label: "Kategorie", value: product.category },
  { label: "Preis", value: product.price },
  ...(product.meta ? [{ label: "Hinweis", value: product.meta }] : [])
];
const savings = Math.max(0, Number(product.compare.marketPriceValue || 0) - Number(product.priceValue || 0));
---

<BaseLayout
  title={`${product.title} | Duschrinnen Profi`}
  description={product.description}
  page={"produkt"}
  ogTitle={`${product.title} | Duschrinnen Profi`}
  ogDescription={product.description}
  preloadImage={heroImage}
>
  <main id="main" data-product-detail-page>
    <section class="product-detail-hero section-band">
      <div class="product-detail-orb product-detail-orb-one" aria-hidden="true"></div>
      <div class="product-detail-orb product-detail-orb-two" aria-hidden="true"></div>
      <div class="product-detail-orb product-detail-orb-three" aria-hidden="true"></div>
      <div class="product-detail-haze" aria-hidden="true"></div>

      <div class="layout product-detail-layout">
        <a class="product-detail-back" href={`/sortiment.html#${anchorTarget}`} data-reveal>
          <i data-lucide="arrow-left" aria-hidden="true"></i>
          <span>Zurück zum Sortiment</span>
        </a>

        <div class="product-detail-shell">
          <article class="product-detail-frame" data-product-detail-shell>
            <div class="product-detail-floating product-detail-floating-one" aria-hidden="true"></div>
            <div class="product-detail-floating product-detail-floating-two" aria-hidden="true"></div>
            <div class="product-detail-floating product-detail-floating-three" aria-hidden="true"></div>

            <div class="product-detail-gallery">
              <div class="product-detail-gallery-head">
                <span>Originalbilder</span>
                <strong>{product.gallery.length} Ansichten</strong>
              </div>

              <div class="product-detail-gallery-note">
                <p>Studiofotos, Lifestyle-Bilder und Detailansichten direkt aus dem bestehenden Sortiment.</p>
                <span>Hover zoom auf Desktop, Tap zoom auf dem Handy.</span>
              </div>

              <div class="product-detail-carousel" data-detail-carousel>
                <button
                  class="product-detail-carousel-button product-detail-carousel-prev"
                  type="button"
                  data-detail-carousel-prev
                  aria-label="Vorheriges Produktbild anzeigen"
                >
                  <i data-lucide="chevron-left" aria-hidden="true"></i>
                </button>

                <div
                  class="product-detail-photo-viewport"
                  data-detail-carousel-viewport
                  tabindex="0"
                  aria-label={`${product.title} Bildergalerie`}
                >
                  <div class="product-detail-photo-track" data-detail-carousel-track>
                    {
                      product.gallery.map((source, index) => {
                        const imageSize = getImageSize(source);
                        return (
                          <figure
                            class={`product-detail-photo-card ${index === 0 ? "is-active is-hero" : ""}`}
                            data-detail-slide
                            aria-hidden={index === 0 ? "false" : "true"}
                          >
                            <div
                              class="product-detail-photo-shell"
                              data-detail-photo-shell
                              tabindex="0"
                              role="button"
                              aria-label={`${product.title} Bild ${index + 1} vergrößern`}
                            >
                              <img
                                src={source}
                                width={imageSize.width}
                                height={imageSize.height}
                                loading={index === 0 ? "eager" : "lazy"}
                                decoding="async"
                                alt={`${product.title} Ansicht ${index + 1}`}
                              />
                            </div>
                            <figcaption>{index === 0 ? "Heroansicht" : `Detailansicht ${index + 1}`}</figcaption>
                          </figure>
                        );
                      })
                    }
                  </div>
                </div>

                <button
                  class="product-detail-carousel-button product-detail-carousel-next"
                  type="button"
                  data-detail-carousel-next
                  aria-label="Nächstes Produktbild anzeigen"
                >
                  <i data-lucide="chevron-right" aria-hidden="true"></i>
                </button>

                <div class="product-detail-carousel-meta">
                  <span data-detail-carousel-count>{product.gallery.length ? `1 / ${product.gallery.length}` : "0 / 0"}</span>
                  <div class="product-detail-thumbs" data-detail-carousel-thumbs aria-label="Produktbild auswählen">
                    {
                      product.gallery.map((source, index) => {
                        const imageSize = getImageSize(source);
                        return (
                          <button
                            class={`product-detail-thumb ${index === 0 ? "is-active" : ""}`}
                            type="button"
                            data-detail-carousel-thumb={index}
                            aria-label={`${product.title} Ansicht ${index + 1} anzeigen`}
                            aria-current={index === 0 ? "true" : "false"}
                          >
                            <img
                              src={source}
                              width={imageSize.width}
                              height={imageSize.height}
                              loading="lazy"
                              decoding="async"
                              alt=""
                            />
                          </button>
                        );
                      })
                    }
                  </div>
                </div>
              </div>
            </div>

            <aside class="product-detail-panel" data-detail-panel>
              <div class="product-detail-panel-inner">
                <div class="product-detail-panel-copy" data-detail-copy>
                  <div class="product-detail-tags">
                    <span>{sectionTitle}</span>
                    {product.meta ? <span>{product.meta}</span> : null}
                    <span>Originalprodukt</span>
                  </div>

                  <p class="eyebrow">{product.category}</p>
                  <h1>{product.title}</h1>
                  <p class="product-detail-lead">{product.shortDescription || product.cardDescription || product.description}</p>
                  <p class="product-detail-description">{product.description}</p>
                  {
                    sectionDescription && sectionDescription !== product.description ? (
                      <p class="product-detail-secondary">{sectionDescription}</p>
                    ) : null
                  }
                  <ul class="product-detail-bullets">
                    <li>Originalfotos und Produktansichten direkt aus dem bestehenden Live-Sortiment.</li>
                    <li>Ruhige Edelstahl-Optik mit schneller Lieferung in 1 bis 2 Werktagen.</li>
                    <li>Perfekt für Modernisierung, Neubau und saubere Walk-in Lösungen.</li>
                  </ul>
                </div>

                <div class="product-detail-panel-base">
                  <div class="product-detail-price-row">
                    <strong>{product.price}</strong>
                    {product.meta ? <span>{product.meta}</span> : null}
                  </div>

                  <dl class="product-detail-facts">
                    {
                      facts.map((fact) => (
                        <div class="product-detail-fact">
                          <dt>{fact.label}</dt>
                          <dd>{fact.value}</dd>
                        </div>
                      ))
                    }
                  </dl>

                  <div class="product-detail-actions">
                    <button class="button button-primary product-detail-cart" type="button" data-add-product={product.title}>
                      <i data-lucide="shopping-bag" aria-hidden="true"></i>
                      <span>In den Warenkorb</span>
                    </button>
                    <a class="button button-ghost dark" href="/kontakt.html">
                      <i data-lucide="messages-square" aria-hidden="true"></i>
                      <span>Beratung anfragen</span>
                    </a>
                  </div>

                  <div class="product-detail-market">
                    <div class="product-detail-market-copy">
                      <span>Marktvergleich</span>
                      <strong>Preis, Design und Ersparnis direkt gegenüberstellen.</strong>
                      <p>{product.compare.advantage}</p>
                      <small>Vergleichbare Marktpreise starten hier bei {product.compare.marketPrice}. Sie sparen aktuell rund {new Intl.NumberFormat("de-DE", { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(savings)} €.</small>
                    </div>
                    <button class="button button-ghost compare-product-button" type="button" data-compare-product={product.title}>
                      <i data-lucide="scale" aria-hidden="true"></i>
                      <span>Mit Markt vergleichen</span>
                    </button>
                  </div>
                </div>
              </div>
            </aside>
          </article>
        </div>
      </div>
    </section>

    {
      relatedProducts.length ? (
        <section class="section-band soft-band">
          <div class="layout">
            <div class="section-heading align-left" data-reveal>
              <p class="eyebrow">Passende Auswahl</p>
              <h2>Mehr aus derselben Produktwelt.</h2>
              <p>Wenn Sie im selben Bereich weitersehen möchten, bleiben Sie hier direkt in der richtigen Kategorie.</p>
            </div>
            <div class="product-grid product-grid-wide">
              {relatedProducts.map((related) => {
                const imageSize = getImageSize(related.image);

                return (
                  <article class="product-card" data-reveal>
                    <div class="product-media-shell">
                      <div
                        class="product-media"
                        data-product-media
                        data-product-title={related.title}
                        data-gallery={related.gallery.join("|")}
                        tabindex="0"
                        role="button"
                        aria-label={`${related.title} vergrößern`}
                      >
                        <img
                          src={related.image}
                          width={imageSize.width}
                          height={imageSize.height}
                          loading="lazy"
                          decoding="async"
                          alt={related.title}
                        />
                      </div>
                      <button
                        class="icon-button product-media-action"
                        type="button"
                        data-open-viewer={related.title}
                        aria-label={`${related.title} Galerie öffnen`}
                      >
                        <i data-lucide="scan-search" aria-hidden="true"></i>
                      </button>
                    </div>
                    <div class="product-body">
                      <p class="product-tag">{related.category}</p>
                      <h2><a href={related.url}>{related.title}</a></h2>
                      <p class="product-body-copy">{related.description}</p>
                      <div class="product-meta">
                        <strong>{related.price}</strong>
                        {related.meta ? <span>{related.meta}</span> : null}
                      </div>
                      <a class="button button-card button-explore" href={related.url} data-explore-product>
                        <i data-lucide="arrow-up-right" aria-hidden="true"></i>
                        <span>Explore</span>
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        </section>
      ) : null
    }
  </main>
</BaseLayout>
